{
  // Backblaze B2 credentials - get these from your B2 account
  // Go to B2 Cloud Storage > Application Keys to generate these
  "backblaze": {
    "applicationKeyId": "YOUR_KEY_ID",
    "applicationKey": "YOUR_APPLICATION_KEY",
    "bucketId": "YOUR_BUCKET_ID"
  },

  // How often to run backups (in minutes)
  "backupFrequencyMinutes": 15,

  // Folders to back up (use double backslashes or forward slashes)
  "folders": [
    "C:\\Users\\YourName\\Documents",
    "C:\\Users\\YourName\\Projects"
  ],

  // Individual files to back up (preserves folder structure)
  "files": [],

  // Folder names to exclude (matches any folder with this name at any depth)
  "excludeFolders": [
    "node_modules",
    ".git",
    "bin",
    "obj",
    "__pycache__",
    "packages",
    ".vs",
    "dist",
    ".next",
    "TestResults",
    "AppPackages"
  ],

  // File extensions to exclude
  "excludeFileTypes": [
    ".tmp",
    ".log",
    ".cache",
    ".suo",
    ".user"
  ],

  // Skip files that match .gitignore rules (requires git on PATH)
  "respectGitIgnore": true,

  // Copy locked files to a temp dir before uploading (e.g. browser extension data)
  "copyToTempOnLock": true,

  // Webhook URL for failure alerts (optional)
  // Supports {MSG} and {DESC} variables - URL-encoded automatically
  "webhookUrl": "",

  // Days to keep old file versions in B2 before cleanup
  "oldVersionRetentionDays": 7
}
